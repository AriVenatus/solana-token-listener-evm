# Telegram API Credentials (Required)
# Get these from https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Bot Settings (Required)
# Two separate forwarding targets are required - one trading bot/chat per
# chain, since Solana and EVM tokens need to go to different bots.
# Format options:
# 1. Username without @ (e.g., odysseus_trojanbot)
# 2. Channel ID (e.g., -1001234567890)

# Where Solana contract addresses get forwarded
TARGET_CHAT_SOLANA=your_solana_trading_bot_here

# Where EVM contract addresses get forwarded (used for whichever EVM chain
# you select at startup/via "Change Blockchain" - Robinhood Chain, Ethereum,
# Base, Arbitrum, BNB Chain, or a custom chain - they all share this one bot)
TARGET_CHAT_EVM=your_evm_trading_bot_here

# Token Tracking Settings (Optional)
# Where to send token tracking notifications
# Default: 'me' (your Saved Messages)
# Format options:
# 1. 'me' for Saved Messages
# 2. Username without @ (e.g., your_alert_channel)
# 3. Channel ID (e.g., -1001234567890)
TRACKING_CHAT=me

# Optional Settings
# Debug mode for additional logging (true/false)
DEBUG=false

# Important Notes:
# 1. Rename this file to '.env'
# 2. Replace the example values with your actual credentials
# 3. Do not use quotes around values
# 4. Do not leave spaces around the = sign
# 5. Make sure TARGET_CHAT_SOLANA/TARGET_CHAT_EVM have no @ symbol or trailing spaces
# 6. TRACKING_CHAT defaults to 'me' if not specified
#
# Which chain is actively monitored (Solana / Robinhood Chain / other EVM
# chains) is NOT set here - it's chosen interactively the first time you run
# the bot, and can be changed later from the app's main menu
# ("Change Blockchain"). The bot automatically forwards to TARGET_CHAT_SOLANA
# or TARGET_CHAT_EVM depending on which chain is active. See README.md for
# the list of supported chains.